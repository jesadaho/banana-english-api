GEMINI_API_KEY=your-gemini-api-key-here
# Comma-separated priority list; first model is primary, rest are fallbacks
GEMINI_CHAT_MODEL=gemini-3.5-flash,gemini-2.5-flash
# Hours to skip a model after 503/high-demand (default 2)
GEMINI_CHAT_MODEL_COOLDOWN_HOURS=2
# Deprecated — append extra models to GEMINI_CHAT_MODEL instead
# GEMINI_CHAT_FALLBACK_MODEL=gemini-2.5-flash
# Primary TTS model only (single id — older Gemini Direct clients don't split commas)
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
# Fallback TTS models for newer clients + server TTS pool (comma-separated)
GEMINI_TTS_FALLBACK_MODELS=gemini-2.5-flash-lite-preview-tts,gemini-2.5-pro-preview-tts
# Hours to skip a TTS model after 503/high-demand (default 2)
GEMINI_TTS_MODEL_COOLDOWN_HOURS=2
GEMINI_TTS_VOICE=Sadachbia
# client = app talks to Gemini TTS directly (default, smoother on Android)
# server = app streams TTS through this backend proxy
DEFAULT_TTS_MODE=client
GROQ_API_KEY=gsk_your-groq-key-here
PORT=8000
DATABASE_URL=postgresql://user:password@localhost:5432/banana_english
FIREBASE_PROJECT_ID=banana-english-ecf11
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Local dev + Flutter web origin; add Railway/public URLs in production
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
ENABLE_DEBUG_ENDPOINTS=true
SESSION_DURATION_SECONDS=300
# Economy — bananas granted to users (defaults match previous hard-coded values)
ONBOARDING_BANANA_BONUS=2
DAILY_BANANA_DROP=1
# DEBUG_BANANA_REFILL=2
